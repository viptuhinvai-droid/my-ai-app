# এই ফাইলটার নাম পরিবর্তন করে ".env" রাখো (শুধু .env, .example বাদ দিয়ে)
# তারপর নিচে তোমার আসল API key বসাও

GEMINI_API_KEY=GEMINI_API_KEY=তোমার_gemini_api_key_এখানে_বসাও
PORT=3001

# OpenAI ব্যবহার করলে এইটা যোগ করো:
# OPENAI_API_KEY=তোমার_openai_key

# Claude ব্যবহার করলে এইটা যোগ করো:
# ANTHROPIC_API_KEY=তোমার_anthropic_key
